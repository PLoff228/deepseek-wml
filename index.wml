<?xml version="1.0"?>
<!DOCTYPE wml PUBLIC "-//WAPFORUM//DTD WML 1.1//EN" "http://www.wapforum.org/DTD/wml_1.1.xml">
<wml>
  <card id="main" title="DeepSeek Bot">
    <p align="center">
      <b>DeepSeek</b><br/>
      Введите вопрос:
    </p>
    <p>
      <input name="question" type="text" emptyok="false" format="*M"/>
      <anchor>Отправить
        <go href="/ask" method="post">
          <postfield name="text" value="$(question)"/>
        </go>
      </anchor>
    </p>
    <p>
      <a href="/settings.wml">⚙ Настройки</a>
    </p>
  </card>
</wml>